# Required
NOTION_TOKEN=ntn_your_notion_integration_token
RITUALFLOW_OUTPUT_PAGE_ID=your_notion_main_page_id

# Generated by `ritualflow setup`
RITUALFLOW_GENERATED_DB_ID=your_generated_db_id
RITUALFLOW_STATS_BLOCK_ID=your_stats_callout_block_id

# Optional — API key for direct Anthropic API calls (falls back to Claude Code CLI)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Optional — model customization (defaults shown)
ANTHROPIC_MODEL=claude-haiku-4-5
CLAUDE_CLI_MODEL=haiku
